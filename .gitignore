# Originals stay local — the site ships optimized derivatives only.
media/raw/*
!media/raw/.gitkeep

# Raw camera video (MOV) never ships; web MP4s in media/video-web do.
*.HEIC
*.heic
*.MOV
*.mov
media/videos/

# Web-ready videos are allowed.
!media/video-web/**

# Archived near-duplicate photos stay local.
media/archive/

.DS_Store
Thumbs.db
__pycache__/
*.pyc
